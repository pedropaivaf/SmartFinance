# Pluggy Open Finance credentials
# Get yours at https://pluggy.ai
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=
PLUGGY_ENV=sandbox

# Proxy server port (default: 3001)
PORT=3001

# RevenueCat public SDK keys (mobile IAP)
# Get yours at https://app.revenuecat.com — Project Settings > API keys
# These are safe to expose on the client (they are public SDK keys).
VITE_REVENUECAT_IOS_KEY=
VITE_REVENUECAT_ANDROID_KEY=
