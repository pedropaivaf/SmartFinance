# Pluggy Open Finance credentials
# Get yours at https://pluggy.ai
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=
PLUGGY_ENV=sandbox

# Proxy server port (default: 3001)
PORT=3001

# RevenueCat public SDK keys (mobile IAP)
# Get yours at https://app.revenuecat.com — Project Settings > API keys
# These are safe to expose on the client (they are public SDK keys).
VITE_REVENUECAT_IOS_KEY=
VITE_REVENUECAT_ANDROID_KEY=

# ── Stripe (web checkout) ─────────────────────────────────────────────────
# These variables live on the Supabase Edge Function side, NOT in the
# client bundle. Set them with:
#   supabase functions secrets set STRIPE_SECRET_KEY=sk_test_...
#   supabase functions secrets set STRIPE_PRICE_MONTHLY=price_...
#   supabase functions secrets set STRIPE_PRICE_ANNUAL=price_...
#   supabase functions secrets set PUBLIC_APP_URL=https://syrosfinance.netlify.app
#
# Listed here for documentation only — the keys below are inert on the
# client. Never commit real values.
# STRIPE_SECRET_KEY=
# STRIPE_PRICE_MONTHLY=
# STRIPE_PRICE_ANNUAL=
# PUBLIC_APP_URL=

# ── Webhook (RevenueCat + Stripe → Supabase) ─────────────────────────────
# Also edge-function secrets only. Deploy with:
#   supabase functions deploy billing-webhook --no-verify-jwt
#   supabase functions secrets set STRIPE_WEBHOOK_SECRET=whsec_...
#   supabase functions secrets set REVENUECAT_WEBHOOK_SECRET=<shared-secret>
# STRIPE_WEBHOOK_SECRET=
# REVENUECAT_WEBHOOK_SECRET=
